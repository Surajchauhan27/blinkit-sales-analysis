
# =====================================================
# 🚀 AuraBot Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# =====================================================

# ─────────────────────────────────────────────────────
# PROVIDER 1: Groq AI ← RECOMMENDED (Free Forever!)
# 14,400 requests/day | No credit card | Super fast
# Get your FREE key at: https://console.groq.com
# ─────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────
# PROVIDER 2: Google Gemini (Backup)
# Get free key at: https://aistudio.google.com
# ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────
# PROVIDER 3: Pollinations AI (always-on, no key needed)
# Automatic fallback — requires no configuration
# ─────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────
# Server Settings
# ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
JWT_SECRET=your-strong-random-jwt-secret-here
